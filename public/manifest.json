{
    "manifest_version": 3,
    "name": "Universal Subtitle Translator",
    "description": "Real-time subtitle translation for any website. OpenAI, Ollama, Google Translate.",
    "version": "3.2.0",
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "128": "icon-128.png",
            "48": "icon-48.png"
        }
    },
    "icons": {
        "48": "icon-48.png",
        "128": "icon-128.png"
    },
    "devtools_page": "devtools.html",
    "options_page": "options.html",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*",
        "file:///*",
        "https://translate.googleapis.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end",
            "all_frames": true
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "content.styles.scss",
                "icon-128.png",
                "icon-48.png"
            ],
            "matches": [
                "http://*/*",
                "https://*/*"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; connect-src 'self' https://*.openai.com https://*.bigmodel.cn https://*.deepseek.com https://translate.googleapis.com https://* http://localhost:* http://127.0.0.1:*; object-src 'self'"
    }
}